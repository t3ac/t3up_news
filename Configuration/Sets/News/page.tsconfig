TCEFORM {
	tt_content {		
		layout {
			disableNoMatchingValueElement = 1
			}			
		}
	}
}

TCEFORM {
	tt_content {
		frame_class {
			removeItems = ruler-before, ruler-after, indent, indent-left, indent-right
			disableNoMatchingValueElement = 1
			types {
				news_newsliststicky {
					addItems { 
						none	= none
						default	= Default					
						white  	= LLL:EXT:t3up/Resources/Private/Language/locallang_backend.xlf:white
						line	= LLL:EXT:t3up/Resources/Private/Language/locallang_backend.xlf:line
					}
				} 
			} // types
		} // frame_class
	} // tt_content  
} // TCEFORM



# News Templates  **********************************************
tx_news.templateLayouts {

        1  = LLL:EXT:t3up_news/Resources/Private/Language/locallang_ts.xlf:teaser
        2  = LLL:EXT:t3up_news/Resources/Private/Language/locallang_ts.xlf:calendar
        3  = LLL:EXT:t3up_news/Resources/Private/Language/locallang_ts.xlf:bigimage
        4  = LLL:EXT:t3up_news/Resources/Private/Language/locallang_ts.xlf:smallimage    
        5  = LLL:EXT:t3up_news/Resources/Private/Language/locallang_ts.xlf:wall             
        
        30 = LLL:EXT:t3up_news/Resources/Private/Language/locallang_ts.xlf:sliderOne 
        31 = LLL:EXT:t3up_news/Resources/Private/Language/locallang_ts.xlf:sliderThree    
        32 = LLL:EXT:t3up_news/Resources/Private/Language/locallang_ts.xlf:sliderFour 
}
